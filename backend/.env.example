# Copy this file to .env and replace the values for your local setup.

# SQLAlchemy database connection string.
DATABASE_URL=sqlite:///database.db

# Use a long random secret in real environments.
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Password for the seeded admin account created by reset_db.py.
ADMIN_PASSWORD=change-me-admin-password

# Comma-separated list of allowed frontend origins. Use * only for local testing.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Public backend URL used for uploaded file links. Do not add a trailing slash.
PUBLIC_URL=http://localhost:5001
