# ============================================================
# EVENTUM BACKEND - Environment Configuration
# ============================================================
# Copy this file to .env:  cp .env.example .env
#
# STEP 1: Choose your environment mode below.
#         Set MODE to "local" for development or "prod" for production.
# STEP 2: Fill in YOUR values in the matching section below.
#         You do NOT need to delete or comment out the other section.
# ============================================================

MODE=local

# ============================================================
# LOCAL DEVELOPMENT SETTINGS
# Used automatically when MODE=local
# ============================================================

LOCAL_DATABASE_URL=sqlite:///database.db
LOCAL_JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
LOCAL_ADMIN_PASSWORD=change-me-admin-password
LOCAL_CORS_ORIGINS=http://localhost:8081,http://localhost:19006
LOCAL_PUBLIC_URL=http://localhost:5001

# ============================================================
# PRODUCTION SETTINGS
# Used automatically when MODE=prod
# ============================================================

PROD_DATABASE_URL=postgresql://eventum_user:YOUR_DB_PASSWORD@localhost/eventum_db
PROD_JWT_SECRET_KEY=GENERATE-A-LONG-RANDOM-SECRET-AT-LEAST-64-CHARS
PROD_ADMIN_PASSWORD=GENERATE-A-STRONG-ADMIN-PASSWORD
PROD_CORS_ORIGINS=https://your-frontend-domain.com
PROD_PUBLIC_URL=http://YOUR_SERVER_IP_OR_DOMAIN
